{
  "manifest_version": 3,
  "name": "Data Conso meter",
  "version": "1.0",
  "permissions": ["storage", "tabs", "activeTab", "downloads", "geolocation", "webRequest", "identity"],
  "host_permissions": ["<all_urls>", "https://api.ember-energy.org/*", "https://*.firebaseio.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
